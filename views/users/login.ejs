<% layout("/layouts/boilerplate") %>

<% const hasError = (typeof error !== 'undefined' && error && error.length > 0); %>

<!-- Immersive Auth Wrapper -->
<div class="immersive-auth-wrapper">
    <!-- 3D Ken Burns Slideshow -->
    <div id="ken-burns-bg" class="ken-burns-slideshow">
        <div class="ken-burns-img img-1"></div>
        <div class="ken-burns-img img-2"></div>
        <div class="ken-burns-img img-3"></div>
    </div>

    <!-- Immersive Welcome Text -->
    <div id="immersive-welcome" class="immersive-welcome-text">
        Wanderlust
    </div>

    <!-- Glassmorphism Auth Card (Popup) -->
    <div id="glass-popup" class="glass-popup-form">
        <div class="text-center mb-4">
            <div class="auth-brand-logo mb-2">
                <i class="fa-solid fa-plane-departure fs-1 text-white"></i>
            </div>
            <h2 class="auth-title fw-bold text-white mb-1" style="font-size: 2.2rem; letter-spacing: -0.5px;">Welcome back</h2>
            <p class="auth-subtitle text-white-50" style="font-size: 1rem;">Sign in to continue your journey</p>
        </div>

        <form action="/login" method="POST" class="needs-validation" novalidate>
            <div class="mb-4 position-relative">
                <label for="username" class="form-label text-white-50 small text-uppercase fw-bold" style="letter-spacing: 1px;">Username</label>
                <div class="input-group">
                    <span class="input-group-text glass-input-group-text px-3"><i class="fa-regular fa-user"></i></span>
                    <input name="username" id="username" type="text" class="form-control glass-input-premium shadow-none" placeholder="Enter your username" required>
                </div>
                <div class="invalid-feedback text-warning ms-1 mt-1"><i class="fa-solid fa-circle-exclamation me-1"></i>Please enter your username.</div>
            </div>

            <div class="mb-5 position-relative">
                <div class="d-flex justify-content-between align-items-end mb-2">
                    <label for="password" class="form-label text-white-50 small text-uppercase fw-bold m-0" style="letter-spacing: 1px;">Password</label>
                    <a href="#" class="small text-white-50 text-decoration-none hover-white transition">Forgot?</a>
                </div>
                <div class="input-group">
                    <span class="input-group-text glass-input-group-text px-3"><i class="fa-solid fa-lock"></i></span>
                    <input name="password" id="password" type="password" class="form-control glass-input-premium shadow-none" placeholder="Enter your password" required>
                </div>
                <div class="invalid-feedback text-warning ms-1 mt-1"><i class="fa-solid fa-circle-exclamation me-1"></i>Please enter your password.</div>
            </div>

            <button type="submit" class="btn btn-premium-submit w-100 py-3 rounded-pill fw-bold fs-5 text-white mb-4">
                Sign In
            </button>
        </form>

        <div class="text-center pt-3 border-top border-secondary border-opacity-25">
            <span class="text-white-50">Don't have an account?</span> 
            <a href="/signup" class="text-white fw-bold text-decoration-none ms-1 hover-scale d-inline-block transition">Sign up</a>
        </div>
    </div>
</div>

<style>
/* Base resets to hide header and footer on auth pages */
nav.navbar, footer, .site-footer { display: none !important; }

/* Custom Overrides for this page */
.btn-premium-submit {
    background: linear-gradient(135deg, #FF385C 0%, #d81b40 100%);
    border: none;
    box-shadow: 0 10px 20px rgba(255, 56, 92, 0.3);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.btn-premium-submit:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 25px rgba(255, 56, 92, 0.4);
}

.btn-premium-submit:active {
    transform: translateY(1px);
}

.hover-white:hover {
    color: white !important;
}

.hover-scale:hover {
    transform: scale(1.05);
}


</style>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const bg = document.getElementById('ken-burns-bg');
    const popup = document.getElementById('glass-popup');
    const welcomeText = document.getElementById('immersive-welcome');

    if (sessionStorage.getItem('introSeen')) {
        // Skip intro
        if (welcomeText) welcomeText.style.setProperty('display', 'none', 'important');
        
        bg.classList.add('blurred');
        bg.style.pointerEvents = 'none';
        
        popup.classList.add('active');
        popup.style.opacity = '1';
        popup.style.visibility = 'visible';
    } else {
        // Play intro
        setTimeout(() => {
            bg.classList.add('blurred');
            popup.classList.add('active');
            
            // Cleanup after animation
            setTimeout(() => {
                bg.style.pointerEvents = 'none';
                if (welcomeText) welcomeText.style.setProperty('display', 'none', 'important');
            }, 500); // Wait for transition to finish
            
            sessionStorage.setItem('introSeen', 'true');
        }, 3000);
    }
});
</script>