<% layout("/layouts/boilerplate")%>

    <div class="container mt-5 mb-5 pb-5">
        <div class="mb-5">
            <h1 class="fw-bold mb-1">Your Wishlist</h1>
            <p class="text-muted">A collection of your favorite places to stay.</p>
        </div>

        <% if (allListings && allListings.length> 0) { %>
            <div class="row row-cols-xxl-4 row-cols-xl-3 row-cols-md-2 row-cols-1 g-4 mt-3">
                <% for(let listing of allListings){ %>
                    <div class="col position-relative stagger-card">
                        <a href="/listings/<%= listing._id %>" class="listing-link">
                            <div class="card h-100 border-0 listing-card hover-lift shadow-hover rounded-4">
                                <div class="card-img-container overflow-hidden rounded-4" style="height: 280px;">
                                    <img src="<%= listing.image.url %>"
                                        class="w-100 h-100 object-fit-cover transition-scale" alt="listing_image">
                                </div>
                                <div class="card-body px-0 pt-3">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <h6 class="fw-bold text-dark mb-1 text-truncate" style="max-width: 85%;">
                                            <%= listing.title %>
                                        </h6>
                                    </div>
                                    <p class="text-muted small mb-1"><i class="fa-solid fa-location-dot me-2"></i>
                                        <%= listing.location %>, <%= listing.country %>
                                    </p>
                                    <div class="d-flex align-items-baseline gap-1 mt-1">
                                        <span class="fw-bold text-dark fs-5">₹<%= listing.price.toLocaleString("en-IN")
                                                %></span>
                                        <span class="text-muted small">night</span>
                                    </div>
                                </div>
                            </div>
                        </a>

                        <form action="/wishlist/<%= listing._id %>" method="POST" class="position-absolute"
                            style="top: 1.5rem; right: 2rem; z-index: 10;">
                            <button
                                class="btn btn-link p-0 border-0 shadow-none text-danger bg-secondary rounded-circle d-flex align-items-center justify-content-center"
                                style="width: 32px; height: 32px;">
                                <i class="fa-solid fa-heart fa-lg"></i>
                            </button>
                        </form>
                    </div>
                    <% } %>
            </div>
            <% } else { %>
                <div class="text-center bg-secondary border rounded-4 p-5 mt-5 shadow-sm mx-auto"
                    style="max-width: 600px; border-style: dashed !important;">
                    <div class="empty-state-icon mb-4">
                        <i class="fa-solid fa-heart-circle-plus display-1 text-danger opacity-25"></i>
                    </div>
                    <h3 class="fw-bold text-dark">Your wishlist is empty</h3>
                    <p class="text-muted px-md-5 mb-4">Save the properties you love to find them easily later. Just
                        click the heart icon on any listing to get started.</p>
                    <a href="/listings"
                        class="btn btn-danger rounded-pill px-5 py-3 fw-bold shadow hover-shadow transition-all"
                        style="background-color: #ff385c; border: none;">
                        Find your first favorite
                    </a>
                </div>
                <% } %>
    </div>