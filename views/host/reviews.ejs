<% layout("/layouts/boilerplate") %>
<div class="container py-5 mt-3">
    <div class="row">
        <%- include("../includes/host-sidebar.ejs") %>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom">
                <h1 class="h2">Guest Reviews</h1>
            </div>

            <!-- Reviews List -->
            <div class="row g-4">
                <% if(reviews.length > 0) { %>
                    <% for(let review of reviews) { %>
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 border-0 shadow-sm rounded-4 p-3 transition hover-shadow-lg">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div class="d-flex align-items-center">
                                            <div class="user-avatar-sm bg-danger text-white rounded-circle me-3 d-flex align-items-center justify-content-center fw-bold" style="width: 40px; height: 40px; font-size: 0.9rem;">
                                                <%= review.author.username.charAt(0).toUpperCase() %>
                                            </div>
                                            <div>
                                                <h6 class="mb-0 fw-bold"><%= review.author.username %></h6>
                                                <span class="text-muted extra-small text-uppercase fw-semibold"><i class="fa-solid fa-house-circle-check me-1 text-danger"></i> <%= review.listingTitle %></span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="star-rating mb-3 text-warning">
                                        <% for(let i=0; i<5; i++) { %>
                                            <i class="fa-<%= i < review.rating ? 'solid' : 'regular' %> fa-star fs-6"></i>
                                        <% } %>
                                    </div>

                                    <p class="card-text text-muted small fst-italic mb-3">"<%= review.comment %>"</p>
                                    
                                    <hr class="border-light">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="text-muted extra-small"><%= new Date(review.createdAt).toLocaleDateString() %></span>
                                        <button class="btn btn-sm btn-link text-danger text-decoration-none fw-semibold p-0">Reply</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% } %>
                <% } else { %>
                    <div class="col-12 text-center py-5">
                        <div class="empty-state py-5">
                            <i class="fa-solid fa-star-half-stroke fs-1 text-muted mb-3 d-block text-warning"></i>
                            <h5>No reviews yet</h5>
                            <p class="text-muted">Once guests leave reviews for your listings, they'll appear here.</p>
                        </div>
                    </div>
                <% } %>
            </div>
        </main>
    </div>
</div>

<style>
    .star-rating .fa-star { margin-right: 2px; }
    .extra-small { font-size: 0.75rem; }
</style>
