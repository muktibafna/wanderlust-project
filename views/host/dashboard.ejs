<% layout("/layouts/boilerplate") %>
<div class="container py-5 mt-3">
    <div class="row">
        <!-- Sidebar -->
        <%- include("../includes/host-sidebar.ejs") %>

        <!-- Main Content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom border-light">
                <h1 class="h2 fw-bold" style="color: #271816;">Host Dashboard</h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <a href="/listings/new" class="btn btn-danger btn-rounded px-4 py-2 shadow-sm fw-bold hover-scale transition">
                        <i class="fa-solid fa-plus me-2"></i> Add New Listing
                    </a>
                </div>
            </div>

            <!-- Stats Cards -->
            <div class="row g-4 mb-5">
                <div class="col-sm-6 col-xl-3">
                    <div class="card h-100 border-0 bg-light rounded-4 text-center p-4 hover-shadow-lg transition">
                        <div class="card-body">
                            <div class="icon-circle bg-danger-subtle text-danger mb-3 mx-auto shadow-sm">
                                <i class="fa-solid fa-house-chimney fs-4"></i>
                            </div>
                            <h3 class="fw-bold mb-1" style="color: #271816;"><%= totalListings %></h3>
                            <p class="text-muted small mb-0 fw-semibold text-uppercase letter-spacing-1">Listings</p>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="card h-100 border-0 bg-light rounded-4 text-center p-4 hover-shadow-lg transition">
                        <div class="card-body">
                            <div class="icon-circle bg-primary-subtle text-primary mb-3 mx-auto shadow-sm">
                                <i class="fa-solid fa-calendar-check fs-4"></i>
                            </div>
                            <h3 class="fw-bold mb-1" style="color: #271816;"><%= totalBookings %></h3>
                            <p class="text-muted small mb-0 fw-semibold text-uppercase letter-spacing-1">Bookings</p>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="card h-100 border-0 bg-light rounded-4 text-center p-4 hover-shadow-lg transition">
                        <div class="card-body">
                            <div class="icon-circle bg-success-subtle text-success mb-3 mx-auto shadow-sm">
                                <i class="fa-solid fa-indian-rupee-sign fs-4"></i>
                            </div>
                            <h3 class="fw-bold mb-1" style="color: #271816;">₹<%= totalEarnings.toLocaleString("en-IN") %></h3>
                            <p class="text-muted small mb-0 fw-semibold text-uppercase letter-spacing-1">Earnings</p>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="card h-100 border-0 bg-light rounded-4 text-center p-4 hover-shadow-lg transition">
                        <div class="card-body">
                            <div class="icon-circle bg-warning-subtle text-warning mb-3 mx-auto shadow-sm">
                                <i class="fa-solid fa-star fs-4"></i>
                            </div>
                            <h3 class="fw-bold mb-1" style="color: #271816;">New</h3>
                            <p class="text-muted small mb-0 fw-semibold text-uppercase letter-spacing-1">Reviews</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Bookings Table -->
            <div class="card border-0 bg-light rounded-4 p-2 mb-4">
                <div class="card-header bg-transparent border-0 pt-4 pb-3 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold" style="color: #271816;">Upcoming Bookings</h5>
                    <a href="/host/bookings" class="text-danger text-decoration-none small fw-bold hover-scale transition">View All <i class="fa-solid fa-arrow-right ms-1"></i></a>
                </div>
                <div class="card-body px-4 pb-4 px-0">
                    <div class="table-responsive">
                        <table class="table table-borderless align-middle mb-0">
                            <thead class="border-bottom border-light text-muted small fw-semibold text-uppercase letter-spacing-1">
                                <tr>
                                    <th class="py-3 px-2">Listing</th>
                                    <th class="py-3">Guest</th>
                                    <th class="py-3">Check-in</th>
                                    <th class="py-3">Check-out</th>
                                    <th class="py-3">Total Price</th>
                                    <th class="py-3">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(upcomingBookings.length > 0) { %>
                                    <% for(let booking of upcomingBookings) { %>
                                        <tr class="border-bottom border-white" style="border-bottom-width: 2px !important;">
                                            <td class="py-3 px-2">
                                                <div class="d-flex align-items-center">
                                                    <img src="<%= booking.listing.image.url %>" class="rounded-3 shadow-sm me-3" width="55" height="45" style="object-fit: cover;">
                                                    <span class="fw-bold text-dark text-truncate" style="max-width: 180px; color: #271816;"><%= booking.listing.title %></span>
                                                </div>
                                            </td>
                                            <td class="text-muted fw-medium"><%= booking.user.username %></td>
                                            <td class="text-muted"><%= new Date(booking.checkIn).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                                            <td class="text-muted"><%= new Date(booking.checkOut).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                                            <td class="fw-bold" style="color: #271816;">₹<%= booking.totalPrice.toLocaleString("en-IN") %></td>
                                            <td>
                                                <span class="badge rounded-pill <%= booking.status === 'Confirmed' ? 'bg-success-subtle text-success' : 'bg-warning-subtle text-warning' %> px-3 py-2 fw-bold">
                                                    <%= booking.status %>
                                                </span>
                                            </td>
                                        </tr>
                                    <% } %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-5">
                                            <div class="empty-state py-4">
                                                <i class="fa-solid fa-calendar-xmark text-muted mb-3 d-block" style="font-size: 3rem;"></i>
                                                <p class="text-muted fw-medium fs-5 mb-0">No upcoming bookings yet.</p>
                                                <p class="text-muted small">When guests book your listings, they will appear here.</p>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<style>
    .btn-rounded { border-radius: 50px; }
    .icon-circle {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .bg-light { background-color: #f8f9fa !important; }
    .letter-spacing-1 { letter-spacing: 1px; }
    
    .hover-shadow-lg:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.06) !important;
    }
    
    .hover-scale { display: inline-block; }
    .hover-scale:hover { 
        transform: scale(1.05); 
    }
    
    .transition { transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); }
    
    .table td { background-color: transparent !important; }
</style>
