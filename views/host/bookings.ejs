<% layout("/layouts/boilerplate") %>
<div class="container py-5 mt-3">
    <div class="row">
        <%- include("../includes/host-sidebar.ejs") %>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom">
                <h1 class="h2">Manage Bookings</h1>
            </div>

            <!-- All Bookings Table -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="px-4 py-3 border-0">Listing Details</th>
                                    <th class="py-3 border-0">Guest Info</th>
                                    <th class="py-3 border-0">Dates</th>
                                    <th class="py-3 border-0">Price</th>
                                    <th class="py-3 border-0">Status</th>
                                    <th class="py-3 border-0">Booked on</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(bookings.length > 0) { %>
                                    <% for(let booking of bookings) { %>
                                        <tr>
                                            <td class="px-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    <img src="<%= booking.listing.image.url %>" class="rounded-3 me-3" width="60" height="45" style="object-fit: cover;">
                                                    <div>
                                                        <span class="fw-bold d-block text-white mb-1"><%= booking.listing.title %></span>
                                                        <span class="text-muted"><i class="fa-solid fa-location-dot me-1 small"></i> <%= booking.listing.location %></span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="d-flex flex-column">
                                                    <span class="fw-semibold"><%= booking.user.name || booking.user.username %></span>
                                                    <span class="text-muted small"><%= booking.user.email %></span>
                                                    <span class="text-muted extra-small"><i class="fa-solid fa-users me-1"></i> <%= booking.guests %> guest(s)</span>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="d-flex flex-column">
                                                    <span class="badge bg-light text-white border p-2 mb-1 fw-medium"><i class="fa-regular fa-calendar-check me-1"></i> <%= new Date(booking.checkIn).toLocaleDateString() %></span>
                                                    <span class="badge bg-light text-white border p-2 fw-medium"><i class="fa-regular fa-calendar-xmark me-1"></i> <%= new Date(booking.checkOut).toLocaleDateString() %></span>
                                                </div>
                                            </td>
                                            <td class="fw-bold">₹<%= booking.totalPrice.toLocaleString("en-IN") %></td>
                                            <td>
                                                <span class="badge rounded-pill <%= booking.status === 'Confirmed' ? 'bg-success' : (booking.status === 'Cancelled' ? 'bg-danger' : 'bg-warning') %>-subtle text-<%= booking.status === 'Confirmed' ? 'success' : (booking.status === 'Cancelled' ? 'danger' : 'warning') %> px-3 py-2">
                                                    <%= booking.status %>
                                                </span>
                                            </td>
                                            <td class="text-muted small">
                                                <%= new Date(booking.createdAt).toLocaleDateString() %>
                                            </td>
                                        </tr>
                                    <% } %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-5">
                                            <div class="empty-state">
                                                <i class="fa-solid fa-calendar-xmark fs-1 text-muted mb-3 d-block text-danger"></i>
                                                <h5>No bookings found yet</h5>
                                                <p class="text-muted">Once guests book your listings, they'll appear here.</p>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<style>
    .extra-small { font-size: 0.75rem; }
    .table thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        color: #666;
    }
</style>
