<style>
  /* ☢️ NUCLEAR Z-INDEX & OVERLAP FIX ☢️ */
  .aurora-navbar, nav.navbar {
    position: sticky !important;
    top: 0 !important;
    z-index: 2147483647 !important; /* Maximum possible CSS value */
    transform: translateZ(0) !important; /* Force top-level GPU stacking context */
  }
  
  .card.sticky-top {
    z-index: 1 !important;
    isolation: isolate !important; /* Traps the booking card in its own low-level layer */
  }

  /* ☢️ NUCLEAR MOBILE DROPDOWN FIX ☢️ */
  @media (max-width: 768px) {
    .navbar .dropdown-menu {
      position: fixed !important;
      top: 80px !important; /* Safely below the navbar */
      right: 15px !important;
      left: 15px !important; /* Stretches safely across the screen */
      width: auto !important;
      max-width: none !important;
      transform: none !important;
      margin: 0 !important;
    }
  }
</style>
<body class="<%= (success && success.length > 0) || (error && error.length > 0) ? 'skip-intro' : '' %>">

