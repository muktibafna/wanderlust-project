<style>
    .custom-flash-alert {
        position: fixed;
        top: -120px;
        left: 50%;
        transform: translateX(-50%) scale(0.95);
        z-index: 10000;
        min-width: 320px;
        max-width: 90vw;
        text-align: center;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.25);


        background: rgba(34, 34, 34, 0.95);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);

        color: white;
        font-size: 1rem;
        font-weight: 500;
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 1rem 2rem;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1rem;
        transition: all 0.6s cubic-bezier(0.19, 1, 0.22, 1);
        pointer-events: none;
        overflow: hidden;
    }


    .custom-flash-alert.active-flash {
        top: 6rem;
        transform: translateX(-50%) scale(1);
    }

    .custom-flash-alert.alert-success {
        border-left: 5px solid #22c55e;
    }

    .custom-flash-alert.alert-danger {
        border-left: 5px solid #ff385c;
    }

    .flash-icon {
        font-size: 1.25rem;
    }

    .alert-success .flash-icon {
        color: #22c55e;
    }

    .alert-danger .flash-icon {
        color: #ff385c;
    }


    .flash-progress {
        position: absolute;
        bottom: 0;
        left: 0;
        height: 3px;
        width: 100%;
        background: rgba(255, 255, 255, 0.2);
    }

    .flash-progress-fill {
        height: 100%;
        width: 100%;
        background: currentColor;
        transition: width 3.5s linear;
    }

    .alert-success .flash-progress-fill {
        background: #22c55e;
    }

    .alert-danger .flash-progress-fill {
        background: #ff385c;
    }
</style>

<% if(success && success.length){ %>
    <div class="alert custom-flash-alert alert-success d-none" id="flashSuccess" role="alert">
        <i class="fa-solid fa-circle-check flash-icon"></i>
        <span>
            <%= success %>
        </span>
        <div class="flash-progress">
            <div class="flash-progress-fill" id="successProgress"></div>
        </div>
    </div>
    <% } %>

        <% if(error && error.length){ %>
            <div class="alert custom-flash-alert alert-danger d-none" id="flashError" role="alert">
                <i class="fa-solid fa-circle-exclamation flash-icon"></i>
                <span>
                    <%= error %>
                </span>
                <div class="flash-progress">
                    <div class="flash-progress-fill" id="errorProgress"></div>
                </div>
            </div>
            <% } %>

                <script>
                    function showFlash(message, type = 'success') {
                        const containerId = type === 'success' ? 'flashSuccess' : 'flashError';
                        const progressId = type === 'success' ? 'successProgress' : 'errorProgress';
                        const iconClass = type === 'success' ? 'fa-circle-check' : 'fa-circle-exclamation';
                        const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';

                        // Remove existing flash if any
                        const existing = document.getElementById(containerId);
                        if (existing) existing.remove();

                        // Create flash element
                        const div = document.createElement('div');
                        div.id = containerId;
                        div.className = `alert custom-flash-alert ${alertClass}`;
                        div.role = 'alert';
                        div.innerHTML = `
                            <i class="fa-solid ${iconClass} flash-icon"></i>
                            <span>${message}</span>
                            <div class="flash-progress">
                                <div class="flash-progress-fill" id="${progressId}"></div>
                            </div>
                        `;

                        document.body.appendChild(div);

                        // Animate
                        requestAnimationFrame(() => {
                            div.classList.add('active-flash');
                            const progressFill = document.getElementById(progressId);
                            if (progressFill) {
                                setTimeout(() => {
                                    progressFill.style.width = '0%';
                                }, 100);
                            }
                        });

                        // Remove after timeout
                        setTimeout(() => {
                            div.classList.remove('active-flash');
                            setTimeout(() => {
                                div.remove();
                            }, 700);
                        }, 3800);
                    }

                    document.addEventListener('DOMContentLoaded', () => {
                        const flashSuccess = document.getElementById('flashSuccess');
                        const flashError = document.getElementById('flashError');

                        function animateExistingFlash(element, progressId) {
                            if (!element) return;
                            element.classList.remove('d-none');
                            
                            requestAnimationFrame(() => {
                                element.classList.add('active-flash');
                                const progressFill = document.getElementById(progressId);
                                if (progressFill) {
                                    setTimeout(() => {
                                        progressFill.style.width = '0%';
                                    }, 100);
                                }
                            });

                            setTimeout(() => {
                                element.classList.remove('active-flash');
                                setTimeout(() => {
                                    element.remove();
                                }, 700);
                            }, 3800);
                        }

                        if (flashSuccess) animateExistingFlash(flashSuccess, 'successProgress');
                        if (flashError) animateExistingFlash(flashError, 'errorProgress');
                    });
                </script>