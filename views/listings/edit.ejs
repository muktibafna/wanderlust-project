<% layout("/layouts/boilerplate") %>

<div class="auth-container mt-5 mb-5 pb-5">
    <div class="auth-card" style="max-width: 800px;">
        <div class="text-center mb-5">
            <h2 class="fw-bold mb-2 text-white">Edit Your Listing</h2>
            <p class="text-muted">Update your property details to keep guests informed.</p>
        </div>

        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">

            <div class="mb-4">
                <label for="title" class="form-label fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Property Title</label>
                <input name="listing[title]" id="title" type="text" class="form-control auth-input shadow-none" value="<%= listing.title %>" required>
                <div class="invalid-feedback">Please provide a catchy title.</div>
            </div>

            <div class="mb-4">
                <label for="description" class="form-label fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Description</label>
                <textarea name="listing[description]" id="description" class="form-control auth-input shadow-none" rows="4" required><%= listing.description %></textarea>
                <div class="invalid-feedback">Describe your place in detail.</div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Original Image Preview</label>
                    <div class="original-image-preview rounded-3 overflow-hidden shadow-sm border">
                        <img src="<%= originalImageUrl %>" class="img-fluid" style="width: 100%; height: 200px; object-fit: cover; opacity: 0.8;">
                    </div>
                </div>
                <div class="col-md-6 d-flex flex-column justify-content-end">
                    <label for="image" class="form-label fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Upload New Image</label>
                    <input name="listing[image]" id="image" type="file" class="form-control auth-input shadow-none">
                    <p class="text-muted extra-small mt-2">Leave blank to keep existing image</p>
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-6 text-start">
                    <label for="price" class="form-label fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Price per Night (₹)</label>
                    <input name="listing[price]" id="price" type="number" class="form-control auth-input shadow-none" value="<%= listing.price %>" required>
                    <div class="invalid-feedback">Please set a valid price.</div>
                </div>
                <div class="col-md-6 text-start">
                    <label for="category" class="form-label fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Vibe/Category</label>
                    <select name="listing[category]" id="category" class="form-select auth-input shadow-none" required style="padding: 0.75rem 1rem;">
                        <% ["Trending", "Rooms", "Iconic cities", "Mountains", "Castles", "Amazing pools", "Camping", "Farms", "Arctic", "Domes", "Boats", "Luxe", "Design", "Amazing views", "Lakefront", "National parks"].forEach(category => { %>
                            <option value="<%= category %>" <%= listing.category === category ? 'selected' : '' %>><%= category %></option>
                        <% }) %>
                    </select>
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-6 text-start">
                    <label for="location" class="form-label fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Location</label>
                    <input name="listing[location]" id="location" type="text" class="form-control auth-input shadow-none" value="<%= listing.location %>" required>
                    <div class="invalid-feedback">Location is required.</div>
                </div>
                <div class="col-md-6 text-start">
                    <label for="country" class="form-label fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Country</label>
                    <input name="listing[country]" id="country" type="text" class="form-control auth-input shadow-none" value="<%= listing.country %>" required>
                    <div class="invalid-feedback">Country is required.</div>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Amenities</label>
                <div class="row g-2">
                    <% ["Wifi", "Parking", "Kitchen", "AC", "Pool", "TV", "Washer", "Gym"].forEach(amenity => { %>
                        <div class="col-6 col-md-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="listing[amenities][]" value="<%= amenity %>" id="amenity-<%= amenity %>" <%= listing.amenities && listing.amenities.includes(amenity) ? 'checked' : '' %>>
                                <label class="form-check-label small" for="amenity-<%= amenity %>">
                                    <%= amenity %>
                                </label>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <button type="submit" class="btn btn-wanderlust w-100 py-3 mt-4 fw-bold fs-5 shadow-sm">Save Changes</button>

        </form>
    </div>
</div>

<script src="/js/script.js"></script>

